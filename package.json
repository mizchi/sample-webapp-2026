{
  "name": "sample-webapp-2026",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "dev": "concurrently -n api,dashboard -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:dashboard\"",
    "dev:api": "node --watch --experimental-strip-types apps/api/src/server.ts",
    "dev:dashboard": "vite --config vite.config.ts",
    "serve:api": "node --experimental-strip-types apps/api/src/server.ts",
    "serve:dashboard": "vite --config vite.config.ts --host 127.0.0.1 --port 4173 --strictPort",
    "preview": "vite preview --config vite.config.ts --host 127.0.0.1 --port 4173",
    "start": "node --experimental-strip-types apps/api/src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "flaker": "node ./scripts/run-flaker.mjs",
    "flaker:run:local": "node ./scripts/run-flaker.mjs run --profile local",
    "flaker:run:scheduled": "node ./scripts/run-flaker.mjs run --profile scheduled",
    "flaker:run:actrun": "node ./scripts/run-flaker.mjs run --runner actrun --profile local",
    "flaker:collect:local": "node ./scripts/run-flaker.mjs collect-local --last 1",
    "flaker:eval:markdown": "node ./scripts/run-flaker.mjs eval --markdown --window 7",
    "vrt": "node ./scripts/run-vrt.mjs",
    "vrt:snapshot": "node ./scripts/vrt-snapshot.mjs",
    "vrt:snapshot:ci": "node ./scripts/vrt-snapshot.mjs --ci",
    "vrt:approve": "node ./scripts/vrt-approve.mjs",
    "report:nightly-context": "node ./scripts/nightly-context.mjs",
    "report:weekly-review": "node --experimental-strip-types ./scripts/weekly-review.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.7",
    "vitest": "^4.1.2"
  }
}
